# Servidor
PORT=3000

# Google Sheets API
# No subas tu API KEY real a GitHub. Crea tu .env local copiando este archivo.
GOOGLE_SHEETS_API_KEY=pon_tu_api_key_aqui
SPREADSHEET_ID=1Q4UTlq2KpoiO840WC7i6zigZLycBlY2Hv1VfviZf9zQ

# Nuevo formato recomendado para tienda grande:
# A:K = Departamento, Categoria, Subcategoria, Nombre, Precio, Imagen, Tallas, Etiqueta, Descripcion, Disponible, Orden
SHEETS_RANGE=A2:K

# Datos de contacto para el pedido por WhatsApp, solo numeros con lada internacional.
WHATSAPP_NUMBER=524451032072

# Si no configuras API KEY, el proyecto usa data/demo-products.json como respaldo.
CACHE_TTL_SECONDS=60
